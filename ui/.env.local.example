# GitHub fine-grained PAT with "Contents: Read and write" permission on this repo
GITHUB_TOKEN=ghp_...

# Your GitHub username or org
GITHUB_OWNER=your-username

# The repo where BACKLOG.md lives
GITHUB_REPO=hopper

# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=...

# Your production URL
NEXTAUTH_URL=https://ui-beryl-pi.vercel.app
